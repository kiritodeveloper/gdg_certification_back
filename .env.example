# ============================================
# CONFIGURACIÓN DE GOOGLE SHEETS
# ============================================
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto o selecciona uno existente
# 3. Habilita "Google Sheets API" y "Google Drive API"
# 4. Crea una cuenta de servicio (Service Account)
# 5. Descarga el JSON de credenciales y pega el contenido aquí
# 6. Comparte tu Google Sheet con el email de la cuenta de servicio

GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"TU_PROYECTO","private_key_id":"TU_KEY_ID","private_key":"TU_PRIVATE_KEY","client_email":"tu-servicio@tu-proyecto.iam.gserviceaccount.com","client_id":"TU_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/tu-servicio%40tu-proyecto.iam.gserviceaccount.com"}

# ID del Google Sheet (lo encuentras en la URL: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
GOOGLE_SHEET_ID=TU_SHEET_ID_AQUI

# Nombre de las hojas dentro del spreadsheet
USERS_SHEET_NAME=usuarios
CERTIFICATES_SHEET_NAME=certificados

# ============================================
# CONFIGURACIÓN DE AUTENTICACIÓN
# ============================================
JWT_SECRET_KEY=cambia-esta-clave-secreta-por-una-mas-segura-12345
JWT_EXPIRATION_HOURS=24

# ============================================
# CONFIGURACIÓN DE EMAIL (para enviar certificados)
# ============================================
EMAIL_SENDER=tu-email@gmail.com
EMAIL_PASSWORD=tu-app-password
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ============================================
# CONFIGURACIÓN DE FLASK
# ============================================
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True

# ============================================
# URL PÚBLICA (para links de activación en emails)
# ============================================
# Cambia esto por la URL real de tu plataforma
# Ejemplo: https://mis-certificados.com  o  http://localhost:5173
BASE_URL=https://tu-dominio.com